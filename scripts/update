#!/usr/bin/env bash
set -euo pipefail

REMOTE="origin"
BRANCH="main"

show_help() {
    cat <<EOF
Usage: $(basename "$0") [OPTION]

Safely switch NixOS configurations using nh, ensuring the git
repository is up to date before switching.

Options:
  --upgrade    Run 'nh os switch -u'
  -h, --help   Show this help message and exit

Environment:
  NH_FLAKE     Path to the Nix flake repository

Examples:
  $(basename "$0")
  $(basename "$0") --upgrade
EOF
}

case "${1:-}" in
-h | --help)
    show_help
    exit 0
    ;;
esac

# Ensure we're in a git repo (adjust if needed)
REPO_DIR="$NH_FLAKE"
cd "$REPO_DIR"

echo "==> Fetching remote updates..."
git fetch "$REMOTE" "$BRANCH"

LOCAL="$(git rev-parse HEAD)"
REMOTE_HEAD="$(git rev-parse "$REMOTE/$BRANCH")"

if [ "$LOCAL" != "$REMOTE_HEAD" ]; then
    echo "❌ Remote has new commits."
    echo "   You must pull before switching."
    echo ""
    echo "Run:"
    echo "  git pull --rebase"
    exit 1
fi

echo "==> Repository is up to date."

UPDATE_FLAG="${1:-}"

if [[ "$UPDATE_FLAG" == "--upgrade" ]]; then
    echo "==> Running: nh os switch -u"
    nh os switch --update --impure
else
    echo "==> Running: nh os switch"
    nh os switch --impure
fi

echo "==> Switch succeeded."

if ! git diff --quiet || ! git diff --cached --quiet; then
    echo "==> Changes detected after switch."
    echo ""

    echo "==> Changed files:"
    git status --short

    echo ""

    read -rp "Commit and push these changes? [y/N] " CONFIRM

    if [[ "$CONFIRM" =~ ^[Yy]$ ]]; then
        echo "==> Staging changes..."
        git add -A

        echo "==> Creating commit..."
        git commit -m "nixos: switch $(date -Iseconds)"

        echo "==> Pushing changes..."
        git push "$REMOTE" "$BRANCH"

        echo "✔ Changes pushed."
    else
        echo "==> Skipping commit and push."
    fi
else
    echo "==> No changes to commit."
fi

echo "✔ Done."
